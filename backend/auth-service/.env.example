# Environment variables for Auth Service

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=emergency_db
DB_SSL=false

# JWT Configuration (CHANGE THESE IN PRODUCTION)
JWT_SECRET=generate-a-secure-random-string-at-least-32-chars
JWT_REFRESH_SECRET=generate-another-secure-random-string-at-least-32-chars
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# Service Configuration
PORT=3001
NODE_ENV=development

# Service URLs (for inter-service communication)
INCIDENT_SERVICE_URL=https://incident-service-ku7i.onrender.com
DISPATCH_SERVICE_URL=https://dispatch-service-w37p.onrender.com
ANALYTICS_SERVICE_URL=https://final-year-013s.onrender.com

