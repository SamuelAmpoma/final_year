# Environment variables for Analytics Service

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=emergency_db

# Service Configuration
PORT=3004
NODE_ENV=development

# Service URLs (for inter-service communication and data fetching)
AUTH_SERVICE_URL=http://localhost:3001
INCIDENT_SERVICE_URL=http://localhost:3002
DISPATCH_SERVICE_URL=http://localhost:3003
